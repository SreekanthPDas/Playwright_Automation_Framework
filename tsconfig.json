{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Node16",
    "moduleResolution": "node16",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",

    "paths": {"@pages": ["src/pages/index.ts"], 
      "@pages/*": ["src/pages/*"],
      "@pageManager/*": ["src/pageManager/*"],
      "@utils/*": ["src/utils/*"],
      "@tests/*": ["src/tests/*"],
      "@test-data/*": ["src/test-data/*"]
    },

    "types": ["node", "@playwright/test"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },

  "include": [
    "src",
    "playwright.config.ts"
  ]
}